FROM node:18-alpine AS builder

WORKDIR /frontend

COPY ./frontend/package.json ./frontend/package-lock.json ./
RUN npm config set legacy-peer-deps true
RUN npm ci --no-audit --no-fund

COPY ./frontend /frontend

ARG REACT_APP_API_BASE_URL
ARG REACT_APP_API_VERSION
ARG REACT_APP_WS_BASE_URL
ARG REACT_APP_COUCHDB_URL
ARG REACT_APP_COUCHDB_USER
ARG REACT_APP_COUCHDB_PASSWORD
ARG REACT_APP_INFLUX_URL
ARG REACT_APP_INFLUX_TOKEN
ARG REACT_APP_INFLUX_ORG
ARG REACT_APP_INFLUX_LIVE_BUCKET
ARG REACT_APP_INFLUX_BACKFILL_BUCKET
ARG REACT_APP_INFLUX_BACKFILL_ALARM_BUCKET
ARG REACT_APP_INFLUX_BACKFILL_LOGS_BUCKET
ARG REACT_APP_INFLUX_ANOMALY_BUCKET
ARG REACT_APP_LAYER_NAME
ARG REACT_APP_DIAGNOSTIC_LAYER_NAME
ARG REACT_APP_ENABLE_REDUX_LOGGER
ARG REACT_APP_ENABLE_ROUTER_DEBUG

ENV REACT_APP_API_BASE_URL=${REACT_APP_API_BASE_URL}
ENV REACT_APP_API_VERSION=${REACT_APP_API_VERSION}
ENV REACT_APP_WS_BASE_URL=${REACT_APP_WS_BASE_URL}
ENV REACT_APP_COUCHDB_URL=${REACT_APP_COUCHDB_URL}
ENV REACT_APP_COUCHDB_USER=${REACT_APP_COUCHDB_USER}
ENV REACT_APP_COUCHDB_PASSWORD=${REACT_APP_COUCHDB_PASSWORD}
ENV REACT_APP_INFLUX_URL=${REACT_APP_INFLUX_URL}
ENV REACT_APP_INFLUX_TOKEN=${REACT_APP_INFLUX_TOKEN}
ENV REACT_APP_INFLUX_ORG=${REACT_APP_INFLUX_ORG}
ENV REACT_APP_INFLUX_LIVE_BUCKET=${REACT_APP_INFLUX_LIVE_BUCKET}
ENV REACT_APP_INFLUX_BACKFILL_BUCKET=${REACT_APP_INFLUX_BACKFILL_BUCKET}
ENV REACT_APP_INFLUX_BACKFILL_ALARM_BUCKET=${REACT_APP_INFLUX_BACKFILL_ALARM_BUCKET}
ENV REACT_APP_INFLUX_BACKFILL_LOGS_BUCKET=${REACT_APP_INFLUX_BACKFILL_LOGS_BUCKET}
ENV REACT_APP_INFLUX_ANOMALY_BUCKET=${REACT_APP_INFLUX_ANOMALY_BUCKET}
ENV REACT_APP_LAYER_NAME=${REACT_APP_LAYER_NAME}
ENV REACT_APP_DIAGNOSTIC_LAYER_NAME=${REACT_APP_DIAGNOSTIC_LAYER_NAME}
ENV REACT_APP_ENABLE_REDUX_LOGGER=${REACT_APP_ENABLE_REDUX_LOGGER}
ENV REACT_APP_ENABLE_ROUTER_DEBUG=${REACT_APP_ENABLE_ROUTER_DEBUG}

RUN npm run build

FROM nginx:1.29-alpine

COPY ./docker-compose/app/nginx.production.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /frontend/build /usr/share/nginx/html
